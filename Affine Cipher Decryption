#include <stdio.h>
int main() {
    char cipher[100];
    int a = 11, b = 10;   // Key found by frequency analysis
    int a_inv = 19;        // Inverse of 11 mod 26
    int i;
    printf("Enter Ciphertext: ");
    scanf("%s", cipher);
    printf("Plaintext: ");
    for(i = 0; cipher[i] != '\0'; i++) {
        int c = cipher[i] - 'A';
        int p = (a_inv * (c - b + 26)) % 26;
        printf("%c", p + 'A');
    }
    return 0;
}
