#include <stdio.h>
#include <string.h>
int main() {
    char text[100];
    char key[] = "QWERTYUIOPASDFGHJKLZXCVBNM";
    int i;
    printf("Enter Plaintext (CAPITAL letters): ");
    scanf("%s", text);
    printf("Ciphertext: ");
    for(i = 0; text[i] != '\0'; i++) {
        if(text[i] >= 'A' && text[i] <= 'Z')
            printf("%c", key[text[i] - 'A']);
        else
            printf("%c", text[i]);
    }
    return 0;
}
