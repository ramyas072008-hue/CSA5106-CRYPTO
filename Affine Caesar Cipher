#include <stdio.h>
#include <ctype.h>
int main() {
    char text[100];
    int a, b, i;
    printf("Enter plaintext: ");
    scanf("%s", text);
    printf("Enter a and b: ");
    scanf("%d%d", &a, &b);
    printf("Ciphertext: ");
    for(i = 0; text[i] != '\0'; i++) {
        char ch = toupper(text[i]);
        printf("%c", ((a * (ch - 'A') + b) % 26) + 'A');
    }
    return 0;
}
