#include <stdio.h>
int main() {
    int key[2][2] = {{9,4},{5,7}};
    int p1[2] = {1,0};   // Plaintext: BA
    int p2[2] = {0,1};   // Plaintext: AB
    printf("Key Matrix:\n");
    printf("%d %d\n%d %d\n", key[0][0], key[0][1], key[1][0], key[1][1]);
    printf("\nChosen Plaintext 1: BA -> Cipher = (%d,%d)\n",
           (9*p1[0]+4*p1[1])%26, (5*p1[0]+7*p1[1])%26);
    printf("Chosen Plaintext 2: AB -> Cipher = (%d,%d)\n",
           (9*p2[0]+4*p2[1])%26, (5*p2[0]+7*p2[1])%26);
    return 0;
}
