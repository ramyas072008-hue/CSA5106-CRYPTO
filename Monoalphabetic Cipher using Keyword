#include <stdio.h>
#include <ctype.h>
int main() {
    char text[100];
    char key[] = "CIPHERABDFGJKLMNOQSTUVWXYZ";
    int i;
    printf("Enter Plaintext: ");
    scanf("%s", text);
    printf("Ciphertext: ");
    for(i = 0; text[i] != '\0'; i++) {
        char ch = toupper(text[i]);
        if(ch >= 'A' && ch <= 'Z')
            printf("%c", key[ch - 'A']);
        else
            printf("%c", ch);
    }
    return 0;
}
